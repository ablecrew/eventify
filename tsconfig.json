{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": ".",
    "paths": {
      "@lib/*": ["./lib/*"],
      "@api/*": ["./api/routes/*"],
      "@types": ["./api/types"]
    }
  },
  "include": ["api/**/*", "lib/**/*", "netlify/**/*"],
  "exclude": ["node_modules", "dist"]
}
