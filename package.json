{
  "name": "eventify",
  "version": "1.0.0",
  "description": "Web App For Eventify App",
  "main": "index.js",
  "scripts": {
    "start": "ts-node -r tsconfig-paths/register api/server.ts",
    "dev": "concurrently \"npm:dev:*\"",
    "dev:server": "nodemon -r tsconfig-paths/register api/server.ts",
    "dev:tsc": "tsc --watch",
    "build": "tsc && cp -R public dist/public && cp -R netlify dist/netlify",
    "preview": "browser-sync start --server 'public' --startPath 'pages/index.html' --files 'public/**/*.*'",
    "netlify:dev": "netlify dev",
    "postinstall": "prisma generate",
    "seed": "ts-node -r tsconfig-paths/register prisma/seed.ts"
  },
  "keywords": [
    "Eventify"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "@neondatabase/serverless": "^1.0.1",
    "@prisma/adapter-neon": "^6.11.1",
    "@prisma/client": "^6.7.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.17",
    "bcryptjs": "^3.0.2",
    "browser-sync": "^3.0.4",
    "cookie-parser": "^1.4.7",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "express": "^5.1.0",
    "flatpickr": "^4.6.13",
    "jsonwebtoken": "^9.0.2",
    "just-validate": "^4.3.0",
    "micromodal": "^0.6.1",
    "module-alias": "^2.2.3",
    "nodemon": "^3.1.10",
    "notyf": "^3.10.0",
    "prisma": "^6.7.0",
    "serverless-http": "^3.2.0",
    "sweetalert2": "^11.21.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    
  },
  "_moduleAliases": {
    "@lib": "./dist/lib",
    "@api": "./dist/api/routes",
    "@types": "./dist/api/types.js"
  }
}
